          "settings": {
            "mappings": {
              "message": "=coerce.toString($activity[SADD][1].Output.SADDResponse) + \"\"+ coerce.toString($activity[SMEMBERS].Output.SMEMBERSResponse)+ \"\" +coerce.toString($activity[SISMEMBER].Output.SISMEMBERResponse) + \"\" +  coerce.toString($activity[SCARD].Output.SCARDResponse) + \"\" + coerce.toString($activity[SREM][1].Output.SREMResponse) + \"\" + coerce.toString($activity[SPOP].Output.SPOPResponse) + \"\" + coerce.toString($activity[SMOVE].Output.SMOVEResponse)"
