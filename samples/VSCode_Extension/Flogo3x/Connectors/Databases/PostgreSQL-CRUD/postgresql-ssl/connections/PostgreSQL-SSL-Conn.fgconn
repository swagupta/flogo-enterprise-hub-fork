  "contrib": "W3siaWQiOiJQb3N0Z3JlU1FMIiwiaXNVc2VyRXh0ZW5zaW9uIjpmYWxzZSwibmFtZSI6IlBvc3RncmVTUUwiLCJyZWYiOiJnaXRodWIuY29tL3RpYmNvL3dpLXBvc3RncmVzL3NyYy9hcHAvUG9zdGdyZVNRTCIsInMzbG9jYXRpb24iOiJUaWJjby9Qb3N0Z3JlU1FMIiwidGFnIjoiMy43LjEtYjAxLXYzLW1haW4iLCJ2ZXJzaW9uIjoiMy43LjEifV0=",
  "data": {
    "ref": "github.com/tibco/wi-postgres/src/app/PostgreSQL/connector/connection",
    "settings": {
      "cacert": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.CA_Certificate\"]",
      "clientcert": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Client_Certificate\"]",
      "clientkey": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Client_Key\"]",
      "connectionretrydelay": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Connection_Retry_Delay\"]",
      "connectiontimeout": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Connection_Timeout\"]",
      "connmaxlifetime": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Maximum_Connection_Lifetime\"]",
      "databaseName": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Database_Name\"]",
      "databaseType": "PostgreSQL",
      "description": "",
      "host": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Host\"]",
      "maxconnectattempts": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Maximum_Connection_Retry_Attempts\"]",
      "maxidleconnection": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Maximum_Idle_Connections\"]",
      "maxopenconnection": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Maximum_Open_Connections\"]",
      "name": "PostgreSQL-SSL-Conn",
      "onprem": false,
      "password": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Password\"]",
      "port": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.Port\"]",
      "tlsconfig": true,
      "tlsparam": "VerifyFull",
      "user": "=$property[\"PostgreSQL.PostgreSQL-SSL-Conn.User\"]"
    }
  },
  "imports": [
    "github.com/tibco/wi-postgres/src/app/PostgreSQL/connector/connection"
  ],
  "type": "flogo:connection"
}