    "name": "ReplyFlow",
    "tasks": [
      {
        "activity": {
          "ref": "github.com/project-flogo/contrib/activity/noop"
        },
        "description": "NoOp Activity",
        "id": "StartActivity",
        "name": "StartActivity"
      },
      {
        "activity": {
          "input": {
            "Log Level": "INFO",
            "flowInfo": false,
            "logLevel": "",
            "message": "=\"Request Message Received is: \"+$flow.message"
          },
          "ref": "github.com/tibco/flogo-general/src/app/General/activity/log"
        },
        "description": "Simple Log Message Activity",
        "id": "LogMessage",
        "name": "LogMessage"
      },
      {
        "activity": {
          "input": {
            "Log Level": "INFO",
            "flowInfo": false,
            "logLevel": "",
            "message": "=\" Request Message headers and Message properties: \"\r\n+coerce.toString($flow.headers)+coerce.toString($flow.messageProperties)"
          },
          "ref": "github.com/tibco/flogo-general/src/app/General/activity/log"
        },
        "description": "Simple Log Message Activity",
        "id": "LogMessage1",
        "name": "LogMessage1"
      },
      {
        "activity": {
          "ref": "github.com/tibco/flogo-ems/src/app/EMS/activity/acknowledge"
        },
        "description": "EMS acknowledge activity acknowledges message in explicit client ack mode",
        "id": "EMSAcknowledge",
        "name": "EMSAcknowledge"
      },
      {
        "activity": {
          "feSchemaMap": {},
          "input": {
            "destination": "=$flow.headers.replyTo",
            "headers": {
              "mapping": {
                "correlationID": "=$flow.headers.correlationID",
                "deliveryMode": "=$flow.headers.deliveryMode",
                "expiration": 0,
                "priority": 4
              }
            },
            "message": "This is a reply msg",
            "messageProperties": "=$flow.messageProperties"
          },
          "ref": "github.com/tibco/flogo-ems/src/app/EMS/activity/sendmessage",
          "schemas": {
            "input": {
              "headers": {
                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"correlationID\":{\"type\":\"string\"},\"replyTo\":{\"type\":\"string\"},\"deliveryMode\":{\"type\":\"string\"},\"expiration\":{\"type\":\"integer\"},\"priority\":{\"type\":\"integer\"}}}",
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"correlationID\":{\"type\":\"string\"},\"replyTo\":{\"type\":\"string\"},\"deliveryMode\":{\"type\":\"string\"},\"expiration\":{\"type\":\"integer\"},\"priority\":{\"type\":\"integer\"}}}"
              },
              "messageProperties": {
