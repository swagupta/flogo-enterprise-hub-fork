                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"property\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"value\":{\"type\":\"string\"},\"type\":{\"type\":\"string\"}},\"required\":[\"name\",\"value\"]}}}}"
              }
            }
          },
          "settings": {
            "connection": "conn://EMSmtlsfalse.fgconn",
            "deliveryDelay": "=$property[\"Deliver_Delay\"]",
            "destinationType": "=$property[\"Destination_Type\"]",
            "settingDestination": "=$property[\"Reply_To_Destination\"]"
          }
        },
        "description": "",
        "id": "EMSSendMessage",
        "name": "EMSSendMessage"
      },
