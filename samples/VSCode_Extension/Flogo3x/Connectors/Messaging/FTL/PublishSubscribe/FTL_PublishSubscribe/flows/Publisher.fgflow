    "name": "Publisher",
    "tasks": [
      {
        "activity": {
          "ref": "github.com/project-flogo/contrib/activity/noop"
        },
        "description": "NoOp Activity",
        "id": "StartActivity",
        "name": "StartActivity"
      },
      {
        "activity": {
          "feSchemaMap": {},
          "input": {
            "compress": "None",
            "input": {
              "mapping": {
                "fileName": "\u003cpath-to-your-file\u003e"
              }
            },
            "readAs": "Binary"
          },
          "ref": "github.com/tibco/flogo-files/src/app/File/activity/read",
          "schemas": {
            "input": {
              "input": {
                "fe_metadata": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}",
                "type": "json",
                "value": "{\"properties\":{\"fileName\":{\"type\":\"string\"}},\"required\":[\"fileName\"],\"type\":\"object\"}"
              }
            },
            "output": {
              "output": {
                "fe_metadata": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"binaryContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}",
                "type": "json",
                "value": "{\"properties\":{\"fileMetadata\":{\"properties\":{\"fullPath\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"size\":{\"type\":\"number\"},\"mode\":{\"type\":\"string\"},\"modTime\":{\"type\":\"string\",\"format\":\"date-time\"},\"isDir\":{\"type\":\"boolean\"}},\"type\":\"object\"},\"fileContent\":{\"properties\":{\"binaryContent\":{\"type\":\"string\"}},\"type\":\"object\"}},\"type\":\"object\"}"
              }
            }
          }
        },
        "description": "This activity reads the content of a file",
        "id": "ReadFile",
        "name": "ReadFile"
      },
      {
        "activity": {
          "feSchemaMap": {},
          "input": {
            "Message": {
              "mapping": {
                "data": "=$activity[ReadFile].output.fileContent.binaryContent"
              }
            }
          },
          "ref": "github.com/tibco/flogo-ftl-connector/src/app/FTL/activity/publisher",
          "schemas": {
            "input": {
              "Message": {
                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"data\":{\"type\":\"string\"}}}",
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"data\":{\"type\":\"string\"}}}"
              }
            }
          },
          "settings": {
            "FTLConManager": "conn://ftlConnection.fgconn",
            "batchCount": 1,
            "destinationName": "read",
            "format": "Opaque",
            "formatName": "",
            "lingerTime": 0,
            "retryDuration": 0,
            "sendPolicy": "Send Inline"
          }
        },
        "description": "Publishes messages to TIBCO FTL destinations (topics/queues)",
        "id": "FTLPublisher",
        "name": "FTLPublisher"
      },
      {
        "activity": {
          "ref": "github.com/project-flogo/contrib/activity/actreturn",
          "settings": {
            "mappings": {
              "code": 200,
              "message": "Message Published"
            }
          }
        },
        "description": "Simple Return Activity",
        "id": "Return",
        "name": "Return"
      }
    ],
