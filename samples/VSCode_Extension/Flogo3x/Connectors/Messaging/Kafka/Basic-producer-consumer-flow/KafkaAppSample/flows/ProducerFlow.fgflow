  "data": {
    "description": "To publish a messages to a topic",
    "explicitReply": true,
    "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjEwMCwieSI6MTAwfSwiS2Fma2FQcm9kdWNlciI6eyJ4IjoxNzMsInkiOjE3OH0sIlJldHVybiI6eyJ4IjozNjksInkiOjE3N319",
    "links": [
      {
        "from": "StartActivity",
        "id": 1,
        "label": "StartActivity to KafkaProducer",
        "to": "KafkaProducer",
        "type": "label"
      },
      {
        "from": "KafkaProducer",
        "id": 2,
        "label": "KafkaProducer to Return",
        "to": "Return",
        "type": "label"
      }
    ],
    "metadata": {
      "fe_metadata": {
        "input": "{\"type\":\"object\",\"title\":\"ReceiveHTTPMessage\",\"properties\":{\"pathParams\":{\"type\":\"object\",\"properties\":{\"message\":{\"type\":\"string\"}},\"required\":[]},\"headers\":{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]},\"requestURI\":{\"type\":\"string\",\"required\":false},\"method\":{\"type\":\"string\",\"required\":false}}}",
        "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"code\":{\"type\":\"integer\",\"required\":false},\"data\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"string\"}}}},\"required\":[]}"
      },
      "input": [
        {
          "name": "pathParams",
          "schema": {
            "type": "json",
            "value": "{\"message\":{\"type\":\"string\"}}"
          },
          "type": "object"
        },
        {
          "name": "headers",
          "schema": {
            "type": "json",
            "value": "{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}}"
          },
          "type": "object"
        },
        {
          "name": "requestURI",
          "type": "string"
        },
        {
          "name": "method",
          "type": "string"
        }
      ],
      "output": [
        {
          "name": "code",
          "type": "integer"
        },
        {
          "name": "data",
          "schema": {
            "type": "json",
            "value": "{\"output\":{\"type\":\"string\"}}"
          },
          "type": "object"
        }
      ]
    },
    "name": "ProducerFlow",
    "tasks": [
      {
        "activity": {
          "ref": "github.com/project-flogo/contrib/activity/noop"
        },
        "description": "NoOp Activity",
        "id": "StartActivity",
        "name": "StartActivity"
      },
      {
        "activity": {
          "input": {
            "ackMode": "All",
            "ackTimeout": 10000,
            "compressionType": "None",
            "frequency": 100,
            "kafkaConnection": "conn://kafkaSSLGCPConn.fgconn",
            "key": "",
            "maxMessages": 0,
            "maxRequestSize": 1048576,
            "partition": 0,
            "partitioner": "Hash",
            "stringValue": "=$flow.pathParams.message",
            "subjects": "String",
            "topic": "=$property[\"topic\"]",
            "valueType": "String",
            "versions": 1
          },
          "ref": "github.com/tibco/flogo-kafka/src/app/Kafka/activity/producer"
        },
        "description": "",
        "id": "KafkaProducer",
        "name": "KafkaProducer",
        "settings": {
          "retryOnError": {
            "count": 0,
            "interval": 0
          }
        }
      },
      {
        "activity": {
          "ref": "github.com/project-flogo/contrib/activity/actreturn",
          "settings": {
            "mappings": {
              "code": 200,
              "data": {
                "mapping": {
                  "output": "=\"Message successfully sent on topic: \"+$activity[KafkaProducer].topic"
                }
              }
            }
          }
        },
        "description": "Simple Return Activity",
        "id": "Return",
        "name": "Return"
      }
    ],
    "triggerHandlers": [
      {
        "action": {
          "input": {
            "headers": "=$.headers",
            "pathParams": "=$.pathParams"
          },
          "output": {
            "code": "=$.code",
            "data": "=$.data"
          }
        },
        "description": "To publish a messages to a topic",
        "reply": {
          "code": 200,
          "configureResponseCodes": false,
          "message": {}
        },
        "schemas": {
          "output": {
            "headers": {
              "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]",
              "type": "json",
              "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}"
            },
            "pathParams": {
              "fe_metadata": "[{\"parameterName\":\"message\",\"type\":\"string\"}]",
              "type": "json",
              "value": "{\"type\":\"object\",\"properties\":{\"message\":{\"type\":\"string\"}},\"required\":[]}"
            }
          },
          "reply": {
            "data": {
              "fe_metadata": "{\"output\":\"string\"}",
              "type": "json",
              "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"string\"}}}"
            },
            "responseBody": {
              "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
              "type": "json",
              "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
            }
          }
        },
        "settings": {
          "Method": "GET",
          "OutputValidation": false,
          "Path": "/produce/{message}",
          "reqType": "application/json"
        },
        "trigger": "trigger://ReceiveHTTPMessage.fgtrigger"
      }
    ]
  },
  "imports": [
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-kafka/src/app/Kafka/activity/producer",
    "github.com/project-flogo/contrib/activity/actreturn"
