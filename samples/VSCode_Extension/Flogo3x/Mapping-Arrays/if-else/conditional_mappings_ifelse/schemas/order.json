{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "ShoppingCartOrder": {
            "type": "object",
            "properties": {
                "Order": {
                    "type": "string"
                },
                "PlacedOn": {
                    "type": "string"
                },
                "Feedback": {
                    "type": "string"
                },
                "Status": {
                    "type": "string"
                },
                "Item": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "Description": {
                                "type": "string"
                            },
                            "Code": {
                                "type": "string"
                            },
                            "Price": {
                                "type": "number"
                            },
                            "Quantity": {
                                "type": "number"
                            }
                        }
                    }
                },
                "Shipment": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "Arriving": {
                                "type": "string"
                            },
                            "DeliveryAddress": {
                                "type": "object",
                                "properties": {
                                    "City": {
                                        "type": "string"
                                    },
                                    "County": {
                                        "type": "string"
                                    },
                                    "Line1": {
                                        "type": "string"
                                    },
                                    "Line2": {
                                        "type": "string"
                                    },
                                    "PostCode": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}