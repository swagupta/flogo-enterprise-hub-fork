        "description": "Simple SubFlow Activity",
        "id": "call_postOrderDetails",
        "name": "call_postOrderDetails",
        "settings": {
          "retryOnError": {
            "count": 0,
            "interval": 0
          }
        }
      },
      {
        "activity": {
          "feSchemaMap": {},
          "input": {
            "input": {
              "mapping": {
                "ShoppingCartOrder": {
                  "@conditional": [
                    {
                      "$activity[call_postOrderDetails].ShoppingCartOrder.ShoppingCartOrder.Status == \"delivered\" || $activity[call_postOrderDetails].ShoppingCartOrder.ShoppingCartOrder.Status == \"completed\"": "=$activity[call_postOrderDetails].ShoppingCartOrder"
                    },
                    {
                      "@otherwise": {
                        "Item": {
                          "@foreach($activity[call_postOrderDetails].ShoppingCartOrder.ShoppingCartOrder.Item,Item)": {
                            "=": "$loop"
                          }
                        },
                        "Order": "=$activity[call_postOrderDetails].ShoppingCartOrder.ShoppingCartOrder.Order",
                        "PlacedOn": "=$activity[call_postOrderDetails].ShoppingCartOrder.ShoppingCartOrder.PlacedOn",
                        "Shipment": {
                          "@foreach($activity[call_postOrderDetails].ShoppingCartOrder.ShoppingCartOrder.Shipment,Shipment)": {
                            "=": "$loop"
                          }
                        },
                        "Status": "=$activity[call_postOrderDetails].ShoppingCartOrder.ShoppingCartOrder.Status"
                      }
                    }
                  ]
                }
              }
            }
          },
          "ref": "github.com/tibco/flogo-general/src/app/General/activity/mapper",
          "schemas": {
            "input": {
              "input": "schema://order.json"
            },
            "output": {
              "output": {
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"ShoppingCartOrder\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"Order\": {\n          \"type\": \"string\"\n        },\n        \"PlacedOn\": {\n          \"type\": \"string\"\n        },\n        \"Feedback\": {\n          \"type\": \"string\"\n        },\n        \"Status\": {\n          \"type\": \"string\"\n        },\n        \"Item\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"Description\": {\n                \"type\": \"string\"\n              },\n              \"Code\": {\n                \"type\": \"string\"\n              },\n              \"Price\": {\n                \"type\": \"number\"\n              },\n              \"Quantity\": {\n                \"type\": \"number\"\n              }\n            }\n          }\n        },\n        \"Shipment\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"Arriving\": {\n                \"type\": \"string\"\n              },\n              \"DeliveryAddress\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"City\": {\n                    \"type\": \"string\"\n                  },\n                  \"County\": {\n                    \"type\": \"string\"\n                  },\n                  \"Line1\": {\n                    \"type\": \"string\"\n                  },\n                  \"Line2\": {\n                    \"type\": \"string\"\n                  },\n                  \"PostCode\": {\n                    \"type\": \"string\"\n                  }\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n}",
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"ShoppingCartOrder\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"Order\": {\n          \"type\": \"string\"\n        },\n        \"PlacedOn\": {\n          \"type\": \"string\"\n        },\n        \"Feedback\": {\n          \"type\": \"string\"\n        },\n        \"Status\": {\n          \"type\": \"string\"\n        },\n        \"Item\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"Description\": {\n                \"type\": \"string\"\n              },\n              \"Code\": {\n                \"type\": \"string\"\n              },\n              \"Price\": {\n                \"type\": \"number\"\n              },\n              \"Quantity\": {\n                \"type\": \"number\"\n              }\n            }\n          }\n        },\n        \"Shipment\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"object\",\n            \"properties\": {\n              \"Arriving\": {\n                \"type\": \"string\"\n              },\n              \"DeliveryAddress\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"City\": {\n                    \"type\": \"string\"\n                  },\n                  \"County\": {\n                    \"type\": \"string\"\n                  },\n                  \"Line1\": {\n                    \"type\": \"string\"\n                  },\n                  \"Line2\": {\n                    \"type\": \"string\"\n                  },\n                  \"PostCode\": {\n                    \"type\": \"string\"\n                  }\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n}"
              }
            }
          }
        },
        "description": "Mapper Activity",
        "id": "conditional_mapping",
        "name": "conditional_mapping"
      },
      {
        "activity": {
          "input": {
            "Log Level": "INFO",
            "flowInfo": false,
            "message": "=utility.renderJSON( $activity[conditional_mapping].output.ShoppingCartOrder, false)"
          },
          "ref": "github.com/tibco/flogo-general/src/app/General/activity/log"
        },
