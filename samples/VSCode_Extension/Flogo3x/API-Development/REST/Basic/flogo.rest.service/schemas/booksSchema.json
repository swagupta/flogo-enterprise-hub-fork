{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "Book": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "number"
                    },
                    "isbn": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "authorName": {
                        "type": "string"
                    },
                    "releaseDate": {
                        "type": "string"
                    },
                    "vintage": {
                        "type": "boolean"
                    },
                    "signed": {
                        "type": "boolean"
                    },
                    "price": {
                        "type": "number"
                    }
                }
            }
        }
    }
}