{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "Book": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "isbn": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "authorName": {
                        "type": "string"
                    },
                    "price": {
                        "type": "number"
                    },
                    "id": {
                        "type": "number"
                    },
                    "description": {
                        "type": "string"
                    },
                    "releaseDate": {
                        "type": "string"
                    },
                    "vintage": {
                        "type": "boolean"
                    },
                    "signed": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "isbn",
                    "name",
                    "authorName",
                    "price",
                    "id",
                    "description",
                    "releaseDate",
                    "vintage",
                    "signed"
                ]
            }
        }
    }
}