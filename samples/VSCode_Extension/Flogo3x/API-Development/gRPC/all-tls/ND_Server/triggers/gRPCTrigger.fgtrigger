{
  "contrib": "",
  "data": {
    "description": "gRPC Trigger",
    "id": "gRPCTrigger",
    "name": "grpc-trigger",
    "ref": "github.com/project-flogo/grpc/trigger/grpc",
    "settings": {
      "enableMTLS": true,
      "enableTLS": true,
      "port": 6443,
      "protoFile": "spec://greet.proto",
      "protoName": "greet",
      "rootCA": {
        "content": "data:application/octet-stream;base64,",
        "filename": "root.pem"
      },
      "serverCert": {
        "content": "data:application/octet-stream;base64,",
        "filename": "server.pem"
      },
      "serverKey": {
        "content": "data:application/octet-stream;base64,",
        "filename": "server-key.pem"
      }
    },
    "title": "gRPCTrigger"
  },
  "imports": [
    "github.com/project-flogo/grpc/trigger/grpc"
  ],
  "type": "flogo:trigger"
}