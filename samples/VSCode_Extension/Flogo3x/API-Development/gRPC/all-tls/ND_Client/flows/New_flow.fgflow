                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"greet\":{\"type\":\"string\"}},\"required\":[]}"
              }
            }
          },
          "settings": {
            "clientCert": {
              "content": "data:application/octet-stream;base64,",
              "filename": "root.pem"
            },
            "clientCert2": {
              "content": "data:application/octet-stream;base64,",
              "filename": "client.pem"
            },
            "clientKey": {
              "content": "data:application/octet-stream;base64,",
              "filename": "client-key.pem"
            },
            "enableMTLS": true,
            "enableTLS": true,
            "hosturl": "localhost:6443",
            "operatingMode": "grpc-to-grpc",
            "protoFile": "spec://greet.proto"
          }
        },
        "description": "gRPC client activity",
        "id": "gRPCInvoke",
        "name": "gRPCInvoke"
