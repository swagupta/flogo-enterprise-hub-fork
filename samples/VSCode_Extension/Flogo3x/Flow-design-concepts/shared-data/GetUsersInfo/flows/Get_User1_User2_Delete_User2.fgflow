  "data": {
    "description": "This is a subflow which contains user1 and user2 info. both flow and app level scope data can be retrieved in a subflow. This flow is also deleting the user2 info and returning a null info later on.",
    "fe_metadata": "",
    "links": [
      {
        "from": "LogMessage",
        "id": 1,
        "label": "LogMessageto",
        "to": "GetUser1Info",
        "type": "expression",
        "value": "$flow.keyInput==$property[\"user1\"] "
      },
      {
        "from": "GetUser1Info",
        "id": 2,
        "label": "GetUser1Info to User1InfoLog",
        "to": "User1InfoLog",
        "type": "label"
      },
      {
        "from": "User1InfoLog",
        "id": 3,
        "label": "User1InfoLog to ReturnUser1Info",
        "to": "ReturnUser1Info",
        "type": "label"
      },
      {
        "from": "LogMessage",
        "id": 4,
        "label": "LogMessage to GetUser2Info",
        "to": "GetUser2Info",
        "type": "expression",
        "value": "$flow.keyInput==$property[\"user2\"]"
      },
      {
        "from": "GetUser2Info",
        "id": 5,
        "label": "GetUser2Info to User2InfoLog",
        "to": "User2InfoLog",
        "type": "label"
      },
      {
        "from": "User2InfoLog",
        "id": 6,
        "label": "User2InfoLog to User2InfoReturn",
        "to": "User2InfoReturn",
        "type": "label"
      },
      {
        "from": "LogMessage",
        "id": 7,
        "label": "LogMessage to DeleteUser2Info",
        "to": "DeleteUser2Info",
        "type": "expression",
        "value": "$flow.keyInput==$property[\"user2\"] \u0026\u0026 $flow.isDelete"
      },
      {
        "from": "DeleteUser2Info",
        "id": 8,
        "label": "DeleteUser2Info to LogUser2delete",
        "to": "LogUser2delete",
        "type": "label"
      },
      {
        "from": "LogUser2delete",
        "id": 9,
        "label": "LogUser2delete to GetUser2InfoPostDelete",
        "to": "GetUser2InfoPostDelete",
        "type": "label"
      },
      {
        "from": "GetUser2InfoPostDelete",
        "id": 10,
        "label": "GetUser2InfoPostDelete to Log_GetUser2InfoPostDelete",
        "to": "Log_GetUser2InfoPostDelete",
        "type": "label"
      },
      {
        "from": "Log_GetUser2InfoPostDelete",
        "id": 11,
        "label": "Log_GetUser2InfoPostDelete to ReturnUser2DeleteInfo",
        "to": "ReturnUser2DeleteInfo",
        "type": "label"
      },
      {
        "from": "LogMessage",
        "id": 12,
        "label": "LogMessage to Return1",
        "to": "Return1",
        "type": "exprOtherwise"
      }
    ],
    "metadata": {
      "fe_metadata": {
        "input": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"keyInput\":{\"type\":\"string\"},\"isDelete\":{\"type\":\"boolean\"}}}",
        "output": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"userInfo\":{\"type\":\"object\",\"properties\":{}}}}"
      },
      "input": [
        {
          "name": "keyInput",
          "type": "string"
        },
        {
          "name": "isDelete",
          "type": "boolean"
        }
      ],
      "output": [
        {
          "name": "userInfo",
          "type": "object"
        }
      ]
    },
    "name": "Get_User1_User2_Delete_User2",
    "tasks": [
